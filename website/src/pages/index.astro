---
import LandingLayout from '../layouts/LandingLayout.astro';

const heroAscii = `▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░
░▒▓█  $ openwarp
█▓▒░  ▸ provider: deepseek
░▒▓█  ▸ model:    v4-pro
█▓▒░  ▸ ssh:      prod-edge
░▒▓█  ▸ block:    ▓▓▓▓▓▓▓▓▓▓
█▓▒░  ▸ context:  cwd=~/openwarp
░▒▓█
█▓▒░  ╭──────────────────────╮
░▒▓█  │  AI agent ready ▌    │
█▓▒░  ╰──────────────────────╯
░▒▓█
█▓▒░  ▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░  ░
░▒▓█  ▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░  ▒
█▓▒░  ▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░  ▓
░▒▓█  ▓▓▒▒░░  ▓▓▒▒░░  ▓▓▒▒░░  █  `;

const logos = ['DeepSeek', 'OpenAI', 'Anthropic', 'Gemini', 'Ollama', 'Kimi', 'Qwen', 'GLM', 'Mistral', 'Together', 'Groq', 'SiliconFlow'];
const repo = 'https://github.com/zerx-lab/warp';
---
<LandingLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="fade-in">
        <h1 data-lang="en">The Open<br/><span class="em">Warp</span> terminal<span class="dot">.</span></h1>
        <h1 data-lang="zh">开放的 <span class="em">Warp</span> 终端<span class="dot">.</span></h1>
        <p class="lede" data-lang="en">A fully decentralized fork of Warp. Six native AI protocols, third-party CLI agents as first-class Blocks, a built-in SSH + tmux host manager. Every credential, conversation and key stays on your machine.</p>
        <p class="lede" data-lang="zh">完全去中心化的 Warp 社区 fork。六套原生 AI 协议、第三方 CLI agent 一等公民、内置 SSH + tmux 管理器。所有凭证、对话与密钥都留在你的机器上。</p>
        <div class="hero-cta">
          <a class="btn" href="#install"><span data-lang="en">Install</span><span data-lang="zh">安装</span><span class="arr">→</span></a>
          <a class="btn alt" href={repo} target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <pre class="ascii-fill">{heroAscii}</pre>
        <span class="badge">v0 · OSS</span>
        <span class="ow-tag">/* OpenWarp ▌ */</span>
      </div>
    </div>
  </section>

  <!-- LOGOS -->
  <div class="logos">
    <div class="logos-track">
      {[...logos, ...logos].map((l) => <span class="item">{l}</span>)}
    </div>
  </div>

  <!-- QUOTE -->
  <section class="quote fade-in">
    <div class="wrap">
      <blockquote>
        <span data-lang="en">“I shouldn't have to ship my prompts, my keys, and my <span class="accent">cwd</span> to a server I don't control just to use a smart terminal.”</span>
        <span data-lang="zh">“我不该为了用一个聪明的终端,就把 prompt、API key 和当前目录全交给一台我不掌控的服务器。”</span>
      </blockquote>
      <div class="who">
        <span data-lang="en"><strong>The thesis behind OpenWarp</strong> · COMMUNITY FORK</span>
        <span data-lang="zh"><strong>OpenWarp 的初衷</strong> · 社区 FORK</span>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="band-dark framed dark" id="how">
    <div class="wrap">
      <div class="ascii-rule">{'+'.padEnd(180, ' +')}</div>
      <div class="sec-head fade-in">
        <div>
          <div class="sec-label"><span class="br">[</span> HOW <span class="br">]</span></div>
          <h2 class="sec-h2" data-lang="en">How <span class="em">OpenWarp</span> handles every prompt.</h2>
          <h2 class="sec-h2" data-lang="zh">每一次对话,OpenWarp <span class="em">是这样处理的</span>.</h2>
          <p class="sec-sub" data-lang="en">OpenWarp keeps the upstream Warp UI — Blocks, Workflows, command suggestions — and replaces the closed AI gateway with explicit, local, editable plumbing.</p>
          <p class="sec-sub" data-lang="zh">OpenWarp 完整保留上游 Warp 的 Blocks / Workflows / 命令建议,只把封闭的 AI gateway 换成显式、本地、可编辑的管线。</p>
        </div>
        <span class="pill" data-lang="en">3 stages</span>
        <span class="pill" data-lang="zh">3 阶段</span>
      </div>

      <div class="how-cards">
        <div class="how-card fade-in">
          <div class="num">STAGE 01</div>
          <div class="ttl" data-lang="en">Captures your block</div>
          <div class="ttl" data-lang="zh">捕获你的 Block</div>
          <div class="desc" data-lang="en">Each command becomes a Block with its cwd, env, exit code — the full unit of context.</div>
          <div class="desc" data-lang="zh">每条命令封装成 Block,带上 cwd / 环境 / 退出码 ── 完整的上下文单元。</div>
          <div class="vis">
            <div class="term-mock">
              <div class="term-mock__bar">
                <div class="term-mock__dots"><span></span><span></span><span></span></div>
                <div class="term-mock__title">~/openwarp <span class="ok">● exit 0</span></div>
              </div>
              <div class="term-mock__body">
                <div class="term-mock__row"><span class="p">$</span> npm run build</div>
                <div class="term-mock__row dim">› vite v5.4 · production</div>
                <div class="term-mock__row dim">› 248 modules transformed</div>
                <div class="term-mock__row"><span class="ok">✓ built in 1.24s</span></div>
                <div class="term-mock__divider"></div>
                <div class="term-mock__row"><span class="term-mock__chip">block</span><span class="dim">cwd · env · stdout · exit</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="how-card fade-in">
          <div class="num">STAGE 02</div>
          <div class="ttl" data-lang="en">Routes to your provider</div>
          <div class="ttl" data-lang="zh">路由到你的 Provider</div>
          <div class="desc" data-lang="en">Your <code>settings.toml</code> picks the model. The request goes straight from your machine to the endpoint — no middle hop, no gateway.</div>
          <div class="desc" data-lang="zh">由 <code>settings.toml</code> 决定走哪个模型。请求从你的设备直连端点,没有中间一跳、没有 gateway。</div>
          <div class="vis">
            <div class="term-mock">
              <div class="term-mock__bar">
                <div class="term-mock__dots"><span></span><span></span><span></span></div>
                <div class="term-mock__title">~/.config/openwarp/settings.toml</div>
              </div>
              <div class="term-mock__body">
                <div class="term-mock__row"><span class="k">[providers.deepseek]</span></div>
                <div class="term-mock__row">protocol = <span class="s">"deepseek"</span></div>
                <div class="term-mock__row">base_url = <span class="s">"https://api.deepseek.com/v1"</span></div>
                <div class="term-mock__row">api_key  = <span class="s">"sk-•••"</span></div>
                <div class="term-mock__divider"></div>
                <div class="term-mock__row"><span class="dim">→</span> POST /chat/completions <span class="ok">200</span> <span class="term-mock__chip ok">direct</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="how-card fade-in">
          <div class="num">STAGE 03</div>
          <div class="ttl" data-lang="en">Streams back into Blocks</div>
          <div class="ttl" data-lang="zh">流式回写到 Block</div>
          <div class="desc" data-lang="en">SSE tokens land in the same Block UI you already know. Local tools — shell / read / edit / search / mcp — execute on box and re-enter the loop.</div>
          <div class="desc" data-lang="zh">SSE token 流式回到熟悉的 Block UI。shell / read / edit / search / mcp 等本地工具就地执行,再回到循环。</div>
          <div class="vis">
            <div class="term-mock">
              <div class="term-mock__bar">
                <div class="term-mock__dots"><span></span><span></span><span></span></div>
                <div class="term-mock__title">block · streaming <span class="ok">● live</span></div>
              </div>
              <div class="term-mock__body">
                <div class="term-mock__row"><span class="term-mock__chip">ai</span><span class="dim">deepseek-reasoner · 18 tools</span></div>
                <div class="term-mock__row term-mock__stream"><span>The </span><span>build </span><span>finished </span><span>in </span><span>1.24s, </span><span>248 mods.</span><span class="term-mock__caret"></span></div>
                <div class="term-mock__divider"></div>
                <div class="term-mock__row dim">tool: <span class="k">read_file</span>(vite.config.ts) <span class="ok">✓</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- providers -->
      <div class="prov-head fade-in">
        <div class="prov-eyebrow"><span class="dot"></span><span data-lang="en">PROVIDERS</span><span data-lang="zh">PROVIDERS · 提供方</span></div>
        <h3 data-lang="en">Bring any provider you want.</h3>
        <h3 data-lang="zh">想接什么 provider,就接什么.</h3>
        <p data-lang="en">Six native protocols — OpenAI / OpenAIResp / Anthropic / Gemini / Ollama / DeepSeek — plus any OpenAI-compatible endpoint. One TOML file, no gateway.</p>
        <p data-lang="zh">六套原生协议 ── OpenAI / OpenAIResp / Anthropic / Gemini / Ollama / DeepSeek ── 加任意 OpenAI 兼容端点。一个 TOML 文件,不走 gateway。</p>
      </div>
      <div class="prov-tabs" role="tablist">
        <span class="prov-tabs-rail" data-prov-rail></span>
        <button class="active" data-pf="frontier" type="button">
          <span class="t" data-lang="en">Frontier</span><span class="t" data-lang="zh">前沿模型</span>
          <span class="c">3</span>
        </button>
        <button data-pf="oss" type="button">
          <span class="t" data-lang="en">Gateways</span><span class="t" data-lang="zh">聚合 / 网关</span>
          <span class="c">3</span>
        </button>
        <button data-pf="local" type="button">
          <span class="t" data-lang="en">Local</span><span class="t" data-lang="zh">本地</span>
          <span class="c">3</span>
        </button>
      </div>

      <div class="prov-grid" data-pf-pane="frontier">
        <article class="prov-card">
          <header>
            <span class="proto native">NATIVE</span>
            <span class="mark">DeepSeek</span>
          </header>
          <h4>deepseek family</h4>
          <ul class="caps">
            <li>thinking</li>
            <li>tools</li>
            <li>1M ctx</li>
            <li>SSE</li>
          </ul>
          <pre class="snip"><span class="k">[providers.deepseek]</span>
protocol = <span class="s">"deepseek"</span>
base_url = <span class="s">"…/v1"</span></pre>
          <p data-lang="en">Native DeepSeek protocol — reasoning trace and tool calling wired through, no compatibility shim.</p>
          <p data-lang="zh">DeepSeek 原生协议,思考链与 tool calling 已打通,没有兼容垫片。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto native">NATIVE</span>
            <span class="mark">Anthropic</span>
          </header>
          <h4>claude 4.x family</h4>
          <ul class="caps">
            <li>tool-use</li>
            <li>prompt cache</li>
            <li>vision</li>
            <li>200k ctx</li>
          </ul>
          <pre class="snip"><span class="k">[providers.anthropic]</span>
protocol = <span class="s">"anthropic"</span>
base_url = <span class="s">"…/v1"</span></pre>
          <p data-lang="en">Tool-use loop, prompt caching and image inputs all bound to the native API.</p>
          <p data-lang="zh">工具循环、prompt cache、图像输入全部绑到原生 API。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto native">NATIVE</span>
            <span class="mark">OpenAI · Gemini</span>
          </header>
          <h4>gpt + gemini</h4>
          <ul class="caps">
            <li>function calling</li>
            <li>responses API</li>
            <li>vision</li>
            <li>SSE</li>
          </ul>
          <pre class="snip"><span class="k">[providers.openai]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"…/v1"</span></pre>
          <p data-lang="en">OpenAI Chat + Responses API and Gemini are first-class — function calling, SSE, no proxy.</p>
          <p data-lang="zh">OpenAI Chat + Responses 与 Gemini 都是一等公民 ── function calling、SSE、不走代理。</p>
        </article>
      </div>

      <div class="prov-grid" data-pf-pane="oss" hidden>
        <article class="prov-card">
          <header>
            <span class="proto compat">OPENAI-COMPAT</span>
            <span class="mark">OpenRouter</span>
          </header>
          <h4>aggregator</h4>
          <ul class="caps">
            <li>one key</li>
            <li>hundreds of models</li>
            <li>routing</li>
          </ul>
          <pre class="snip"><span class="k">[providers.router]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"openrouter.ai/api/v1"</span></pre>
          <p data-lang="en">Point <code>base_url</code> at OpenRouter — one key reaches the whole catalog.</p>
          <p data-lang="zh">把 <code>base_url</code> 指到 OpenRouter,一把 key 接入全目录。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto compat">OPENAI-COMPAT</span>
            <span class="mark">Qwen · GLM · Kimi</span>
          </header>
          <h4>chinese frontier</h4>
          <ul class="caps">
            <li>SiliconFlow</li>
            <li>DashScope</li>
            <li>Z.ai</li>
            <li>Moonshot</li>
          </ul>
          <pre class="snip"><span class="k">[providers.kimi]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"api.moonshot.cn/v1"</span></pre>
          <p data-lang="en">Self-hosted or hosted — any OpenAI-compatible endpoint just works.</p>
          <p data-lang="zh">自托管或托管均可,任意 OpenAI 兼容端点直连。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto compat">OPENAI-COMPAT</span>
            <span class="mark">Groq · Together</span>
          </header>
          <h4>fast inference</h4>
          <ul class="caps">
            <li>low latency</li>
            <li>OSS models</li>
            <li>SSE</li>
          </ul>
          <pre class="snip"><span class="k">[providers.groq]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"api.groq.com/openai/v1"</span></pre>
          <p data-lang="en">Production-grade hosted inference — drop-in via the OpenAI-compatible adapter.</p>
          <p data-lang="zh">生产级托管推理 ── 通过 OpenAI 兼容适配器直接接入。</p>
        </article>
      </div>

      <div class="prov-grid" data-pf-pane="local" hidden>
        <article class="prov-card">
          <header>
            <span class="proto native">NATIVE</span>
            <span class="mark">Ollama</span>
          </header>
          <h4>ollama</h4>
          <ul class="caps">
            <li>no keys</li>
            <li>no network</li>
            <li>localhost:11434</li>
          </ul>
          <pre class="snip"><span class="k">[providers.ollama]</span>
protocol = <span class="s">"ollama"</span>
base_url = <span class="s">"http://127.0.0.1:11434"</span></pre>
          <p data-lang="en">First-class Ollama protocol bound — no key, no network, just <code>ollama serve</code>.</p>
          <p data-lang="zh">原生 Ollama 协议直连,不要 key、不出网,只需要 <code>ollama serve</code>。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto compat">OPENAI-COMPAT</span>
            <span class="mark">LM Studio</span>
          </header>
          <h4>lm studio</h4>
          <ul class="caps">
            <li>GUI loader</li>
            <li>localhost:1234</li>
            <li>GGUF</li>
          </ul>
          <pre class="snip"><span class="k">[providers.lmstudio]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"http://127.0.0.1:1234/v1"</span></pre>
          <p data-lang="en">Drop-in OpenAI-compatible endpoint — point <code>base_url</code> and you're done.</p>
          <p data-lang="zh">即插即用的 OpenAI 兼容端点 ── 改 <code>base_url</code> 就完事。</p>
        </article>

        <article class="prov-card">
          <header>
            <span class="proto compat">OPENAI-COMPAT</span>
            <span class="mark">vLLM · TGI</span>
          </header>
          <h4>your cluster</h4>
          <ul class="caps">
            <li>self-hosted</li>
            <li>fine-tunes</li>
            <li>tensor parallel</li>
          </ul>
          <pre class="snip"><span class="k">[providers.vllm]</span>
protocol = <span class="s">"openai"</span>
base_url = <span class="s">"http://gpu-01:8000/v1"</span></pre>
          <p data-lang="en">Production-grade inference on your own hardware, fine-tunes included.</p>
          <p data-lang="zh">生产级推理跑你自己的硬件,微调模型一并支持。</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ADAPTS -->
  <section class="band-light" id="adapt">
    <div class="wrap">
      <div class="ascii-rule">{'~'.repeat(160)}</div>
      <div class="sec-label"><span class="br">[</span> 02 / 04 <span class="br">]</span></div>
      <h2 class="sec-h2 fade-in" data-lang="en">Adapts to <span class="em">your terminal</span>.</h2>
      <h2 class="sec-h2 fade-in" data-lang="zh">完全 <span class="em">服从</span> 你的终端.</h2>
      <p class="sec-sub" data-lang="en">Your provider, your prompts, your CLI agents. The AI side of OpenWarp is your house — not ours.</p>
      <p class="sec-sub" data-lang="zh">你的 provider、你的 prompt、你的 CLI agent。OpenWarp 的 AI 层只是房子,屋主始终是你。</p>

      <div class="reviews-grid three">
        <div class="review-card fade-in">
          <div class="h" data-lang="en">Bring your own provider</div>
          <div class="h" data-lang="zh">自带 Provider</div>
          <div class="d" data-lang="en">Point at any OpenAI-compatible endpoint, or speak the native protocol of DeepSeek / Anthropic / Gemini / Ollama.</div>
          <div class="d" data-lang="zh">指向任意 OpenAI 兼容端点,或直接走 DeepSeek / Anthropic / Gemini / Ollama 的原生协议。</div>
          <div class="vis">
            <pre class="mini-toml"><span class="c"># settings.toml</span>
<span class="k">[providers.deepseek]</span>
base_url = <span class="s">"https://api.deepseek.com/v1"</span>
protocol = <span class="s">"deepseek"</span>
api_key  = <span class="s">"sk-•••"</span></pre>
          </div>
        </div>

        <div class="review-card fade-in">
          <div class="h" data-lang="en">Editable prompts, minijinja roles</div>
          <div class="h" data-lang="zh">可编辑 Prompt · minijinja 模板</div>
          <div class="d" data-lang="en">8 templates ported from opencode, rendered live by minijinja against cwd / language / role. Switch per Block — no server round-trip.</div>
          <div class="d" data-lang="zh">8 套从 opencode 移植的模板,minijinja 按 cwd / 语言 / 角色实时渲染,每个 Block 独立切换 ── 不走服务端。</div>
          <div class="vis role-list">
            <span class="chip k">default</span>
            <span class="chip">anthropic</span>
            <span class="chip">gpt</span>
            <span class="chip">beast</span>
            <span class="chip">gemini</span>
            <span class="chip">kimi</span>
            <span class="chip">codex</span>
            <span class="chip">trinity</span>
          </div>
        </div>

        <div class="review-card fade-in">
          <div class="h" data-lang="en">Bring any CLI agent</div>
          <div class="h" data-lang="zh">任何 CLI agent 都能进 Block</div>
          <div class="d" data-lang="en">First-class adapters for DeepSeek-TUI, Codex CLI and Claude Code. OSC9 / OSC777 routes their notifications into the same Block lifecycle and notification center.</div>
          <div class="d" data-lang="zh">已为 DeepSeek-TUI / Codex CLI / Claude Code 接好 first-class 适配,OSC9 / OSC777 把它们的通知统一收进 Block 生命周期与通知中心。</div>
          <div class="vis agent-list">
            <span class="chip">deepseek-tui</span>
            <span class="chip">codex</span>
            <span class="chip">claude-code</span>
            <span class="chip ext">your-agent</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SSH MANAGER -->
  <section class="band-dark dark" id="layer">
    <div class="wrap">
      <div class="ascii-rule">{'─ '.repeat(80)}</div>
      <div class="sec-head fade-in">
        <div>
          <div class="sec-label"><span class="br">[</span> 03 / 04 <span class="br">]</span></div>
          <h2 class="sec-h2" data-lang="en">A <span class="em">first-class</span> SSH manager.</h2>
          <h2 class="sec-h2" data-lang="zh">一等公民的 <span class="em">SSH 管理</span>.</h2>
          <p class="sec-sub" data-lang="en">Net-new in OpenWarp on top of upstream Warp. Saved hosts, jump-host chains, Block-aware remote sessions — all backed by your existing <code>~/.ssh</code>.</p>
          <p class="sec-sub" data-lang="zh">OpenWarp 在上游基础上新增的能力。保存主机、跳板链、Block 感知的远端会话 ── 全部沿用你现有的 <code>~/.ssh</code>。</p>
        </div>
        <span class="pill" data-lang="en">net-new</span>
        <span class="pill" data-lang="zh">本仓新增</span>
      </div>

      <div class="cv-cards">
        <div class="cv-card fade-in">
          <div class="num">01</div>
          <div class="vis">
            <div class="term-mock">
              <div class="term-mock__bar">
                <div class="term-mock__dots"><span></span><span></span><span></span></div>
                <div class="term-mock__title">ssh · hosts</div>
              </div>
              <div class="term-mock__body">
